#!/bin/sh
# Punto de entrada unico del Harness (Rust only, post-migracion).
# Despacha SIEMPRE al binario nativo (harness / harness.exe).
# Los hooks/scripts/docs usan SIEMPRE `sh harness_cli <cmd>`.
# Sin binario: error (ya no hay fallback Python).
DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
for exe in "$DIR/harness" "$DIR/harness.exe"; do
    if [ -x "$exe" ]; then
        exec "$exe" "$@"
    fi
done
echo "[harness_cli] Binario 'harness' no encontrado en $DIR." >&2
echo "Ejecuta setup_harness.sh con rust/cargo disponible para compilar el binario." >&2
exit 127
